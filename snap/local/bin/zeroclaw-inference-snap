#!/bin/sh
# zeroclaw-inference-snap — interactive inference snap picker for ZeroClaw.
#
# Discovers installed Canonical inference snaps, probes their OpenAI-compatible
# APIs, presents a menu to choose one, writes the choice into
# ~/.zeroclaw/config.toml as the active provider, and restarts the gateway.
#
# Run as:  zeroclaw.inference-snap
#
# Requires classic confinement: reads /var/snap/<snap>/current/share/status/status.json
# for endpoint discovery; falls back to the snap CLI if the file is absent.

export PATH="$SNAP/bin:$PATH"
CURL="$SNAP/usr/bin/curl"

CLI="zeroclaw"
INFERENCE_SNAPS="${CLAW_INFERENCE_SNAPS:-gemma3 gemma4 deepseek-r1 nemotron-3-nano nemotron-3-nano-omni qwen-vl}"

CONFIG_DIR="$HOME/.zeroclaw"
CONFIG_FILE="$CONFIG_DIR/config.toml"
SERVICE_NAME="$CLI"

log() { printf '%s: %s\n' "$CLI" "$1"; }
err() { printf '%s: %s\n' "$CLI" "$1" >&2; }

# Returns "http://HOST:PORT" (no path) since zeroclaw constructs the full URL
# itself by appending the default /v1/chat/completions suffix.
get_snap_api_base() {
  sname="$1"
  # Prefer the standardized status file — avoids the TTY-output CLI issue
  # where `<snap> get <key>` writes directly to /dev/tty rather than stdout.
  # Strip the path (e.g. /v1) to return just http://HOST:PORT.
  status_file="/var/snap/${sname}/current/share/status/status.json"
  if [ -f "$status_file" ]; then
    openai_url=$(grep -o '"openai"[[:space:]]*:[[:space:]]*"[^"]*"' "$status_file" \
      | sed 's/.*"openai"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
    if [ -n "$openai_url" ]; then
      printf '%s' "$openai_url" | sed 's|/[^/]*$||'
      return 0
    fi
  fi
  # Fallback: CLI-based detection for snaps without a status file
  snap list "$sname" >/dev/null 2>&1 || return 1
  host=$("$sname" get http.host 2>/dev/null)
  port=$("$sname" get http.port 2>/dev/null)
  [ -z "$port" ] && return 1
  host="${host:-127.0.0.1}"
  printf 'http://%s:%s' "$host" "$port"
}

probe_models() {
  "$CURL" -sf --connect-timeout 3 --max-time 5 "${1}/v1/models" 2>/dev/null \
    | grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' \
    | sed 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
}

write_config() {
  provider="$1"
  api_base="$2"
  model_id="$3"
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" << ZEROCLAW_CFG
default_provider = "openai"
api_url = "${api_base}"
default_model = "${model_id}"
ZEROCLAW_CFG
}

ENTRIES=""
for sname in $INFERENCE_SNAPS; do
  api_base=$(get_snap_api_base "$sname") || continue
  models=$(probe_models "$api_base")
  [ -z "$models" ] && continue
  for mid in $models; do
    ENTRIES="${ENTRIES}${sname}|${api_base}|${mid}
"
  done
done
ENTRIES=$(printf '%s' "$ENTRIES" | sed '/^$/d')
COUNT=$(printf '%s\n' "$ENTRIES" | grep -c .)

if [ "$COUNT" -eq 0 ]; then
  err "no inference snaps detected"
  err "install one with: sudo snap install gemma4"
  err "then run '${CLI}.inference-snap' again"
  exit 1
fi

if [ ! -t 0 ] || [ ! -t 1 ]; then
  ENTRY=$(printf '%s\n' "$ENTRIES" | head -1)
  _sname=$(printf '%s' "$ENTRY" | cut -d'|' -f1)
  _base=$(printf '%s' "$ENTRY" | cut -d'|' -f2)
  _mid=$(printf '%s' "$ENTRY" | cut -d'|' -f3)
  write_config "$_sname" "$_base" "$_mid"
  log "configured ${_sname}/${_mid} (non-interactive)"
  systemctl --user restart "$SERVICE_NAME" >/dev/null 2>&1 || true
  exit 0
fi

printf '\n%s detected the following inference snaps:\n\n' "$CLI"
i=1
printf '%s\n' "$ENTRIES" | while IFS= read -r entry; do
  [ -z "$entry" ] && continue
  _sname=$(printf '%s' "$entry" | cut -d'|' -f1)
  _base=$(printf '%s' "$entry" | cut -d'|' -f2)
  _mid=$(printf '%s' "$entry" | cut -d'|' -f3)
  printf '  %d. %s/%s  (%s)\n' "$i" "$_sname" "$_mid" "$_base"
  i=$((i + 1))
done
printf '\n'

while true; do
  printf 'Model number [1]: '
  read -r choice
  [ -z "$choice" ] && choice=1
  case "$choice" in
    ''|*[!0-9]*) continue ;;
  esac
  if [ "$choice" -ge 1 ] && [ "$choice" -le "$COUNT" ]; then
    break
  fi
done

ENTRY=$(printf '%s\n' "$ENTRIES" | sed -n "${choice}p")
SNAME=$(printf '%s' "$ENTRY" | cut -d'|' -f1)
BASE=$(printf '%s' "$ENTRY" | cut -d'|' -f2)
MID=$(printf '%s' "$ENTRY" | cut -d'|' -f3)

write_config "$SNAME" "$BASE" "$MID"
log "primary model -> ${SNAME}/${MID}"
log "wrote ${CONFIG_FILE}"

if systemctl --user restart "$SERVICE_NAME" >/dev/null 2>&1; then
  log "restarted the gateway service"
else
  log "run 'systemctl --user restart ${SERVICE_NAME}' to apply"
fi
